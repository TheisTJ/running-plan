# Supabase cross-device sync (optional).
# Copy to `.env` for local dev, and set the same values as repo secrets for the
# GitHub Pages deploy workflow. Both are PUBLIC by design — the anon key ships
# in the static bundle; access to your data is gated by the unguessable sync
# code, not by these values. Leave unset to run local-only (localStorage).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
